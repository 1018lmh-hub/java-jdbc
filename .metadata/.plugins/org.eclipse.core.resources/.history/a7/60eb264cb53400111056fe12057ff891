package com.kh.start.run;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.ResultSet;
import java.sql.SQLException;
import java.sql.Statement;

public class SelectSupplementsRun {

	public static void main(String[] args) {
		
		Connection conn = null;
		Statement stmt = null;
		ResultSet rset = null;

		String sql = """
						SELECT
						       SUP_NO
						     , SUP_NAME
						     , SUP_PRICE
						     , PILLS
						  FROM
						       SUPPLEMENTS
						 ORDER
						    BY
						       SUP_NO DESC
					""";
		
		
		try {
			Class.forName("oracle.jdbc.driver.OracleDriver");
			conn = DriverManager.getConnection("jdbc:oracle:thin:@127.0.0.1:1521:XE",
										"C##MH",
										"MH");
			stmt = conn.createStatement();
			rset = stmt.executeQuery(sql);
			
			while(rset.next()) {
				int supId = rset.getInt("SUP_NO");
				String supName = rset.getString("SUP_NAME");
				int supPrice = rset.getInt("SUP_PRICE");
				int pills = rset.getInt("PILLS");
				
				System.out.println("번호 : " + supId
							   + ", 영양제 이름" + supName
							   + ", 영양제 가격" + supPrice
							   + ", 알약 수" + pills);
			}
		} catch (SQLException e) {
			e.printStackTrace();
		} catch (ClassNotFoundException e) {
			e.printStackTrace();
		} finally {
			try {
				if(rset != null && !rset.isClosed()) {
				rset.close();
				}
				if(stmt != null && stmt.isClosed()) {
				stmt.close();
				}
				if(conn !=null && conn.isClosed()) {
				conn.close();
				}
			} catch (SQLException e) {
				e.printStackTrace();
			}
		
		}
		
	}

}
