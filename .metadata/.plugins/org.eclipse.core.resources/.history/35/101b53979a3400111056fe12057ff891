package com.kh.start.run;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.SQLException;
import java.sql.Statement;
import java.util.Scanner;

public class InsertRun {

	public static void main(String[] args) {
		//반복 계속해보기 -> 손이 기억할 때까지
		//JDBC 맛보기
		/*
		 * Java를 사용하지 않았을 때 ZONE 테이블에 한 행 인서트하려면 어떤 절차가 필요했지?
		 * 
		 * 1. PC 켜기
		 * 2. 디비버 실행(클라이언트 프로그램)
		 * 3. 접속하기(콘센트) 누름
		 * 4. Oracle 선택
		 * 5. IP 주소, PORT 번호, 사용자 이름, 비밀번호가지고 연결
		 * 6. 새 SQL 편집기
		 * 7. INSERT 문 작성 => INSERT INTO ZONE VALUES('값', '값', '값')
		 * 8. SQL문 실행
		 * 9. UpdateRows : 1
		 * 10. COMMIT
		 * 
		 * JDBC API
		 * 
		 * 경계 규약
		 * 이게 인터페이스였나
		 * 장치 프로그램들끼리 연결
		 * 
		 * 
		 */
		
		// 0) 필요한 변수 세팅
		Connection conn = null;
		Statement stmt = null;
		
		int result = 0;
		
		//사용자가 입력한 값을 DBMS로 보내서 => ZONE 테이블에 INSERT
		
		Scanner sc = new Scanner(System.in);
		
		String sql = "INSERT INTO ZONE VALUES('50', '테스트', '테스트')";
		
		//나는 오라클 DBMS에다가 작업할거다!
		
		// 오라클 DBMS 오라클드라이버클래스
	
		//리플랙션을 사용해서 동적으로 클래스 로드
		
		try {
			//1) JDBC Driver 등록 -> ORACLE -> ojdbc.jar
			Class.forName("oracle.jdbc.driver.OracleDriver");
			System.out.println("Driver등록 성공!");
			
			//2) DB 서버랑 연결(IP주소, PORT번호, 사용자이름, 비밀번호)
			conn = DriverManager.getConnection("jdbc:oracle:thin:@127.0.0.1:1521:XE", //IP에서 구분절은 보통 @를 씀 
										"C##MH", 
										"MH");
			System.out.println("DB연결 성공!");
			//URL 은 프로그램명, 버전에 따라서 달라짐 홈페이지에 찾아서 기기
			
			//학습을 위해 오토커밋 끄기
			conn.setAutoCommit(false);
			
			// 3) 새 SQL편집기 열기
			stmt = conn.createStatement();
			System.out.println("Statement객체 생성!");
			
			// 4) SQL문 실행
			// executeUpdate(DML문)
			stmt.executeUpdate(sql);
			
			
		} catch (ClassNotFoundException e) {
			e.printStackTrace();
		} catch (SQLException e) {
			e.printStackTrace();
		}
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		

	}

}
