package com.kh.start.run;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.SQLException;
import java.sql.Statement;
import java.util.Scanner;

public class InsertSupplementsRun {

	public static void main(String[] args) {
	
		Connection conn = null;
		Statement stmt = null;
		int result = 0;
		
		Scanner sc = new Scanner(System.in);
		
		System.out.print("SUP_NAME을 입력해주세요 > ");
		String supName = sc.nextLine();
		System.out.print("SUP_PRICE을 입력해주세요 > ");
		String supPrice = sc.nextLine();
		System.out.print("PILLS을 입력해주세요 > ");
		String pills = sc.nextLine();
		
		StringBuilder sb = new StringBuilder();
		
		sb.append("CREATE SEQUENCE SEQ_ZONE_ID START WITH 4 NOCACHE");
		sb.append("INSERT INTO SUPPLEMENTS VALUES(");
		sb.append("SEQ_ZONE_ID.NEXTVAL, ");
		sb.append("'" + supName + "', ");
		sb.append(supPrice + ", ");
		sb.append(pills + ")");
		
		try {
			Class.forName("oracle.jdbc.driver.OracleDriver");
			System.out.println("Driver등록 성공!");
			conn = DriverManager.getConnection("jdbc:oracle:thin:@127.0.0.1:1521:XE",
					"C##MH",
					"MH");
			System.out.println("DB연결성공!");
			conn.setAutoCommit(false);
			stmt = conn.createStatement();
			System.out.println("Statement객체 생성!");
			result = stmt.executeUpdate(sb.toString());
			System.out.println("SQL문 실행 성공!");
			if(result > 0) {
				conn.commit();
			}
			
		} catch (ClassNotFoundException e) {
			e.printStackTrace();
		} catch (SQLException e) {
			e.printStackTrace();
		} finally {
			try {
				stmt.close();
				conn.close();
			} catch (SQLException e) {
				e.printStackTrace();
			}
			sc.close();
		}
	
	
		
		
		
		
		

		/*
		 * 시퀀스 사용 방법
		 * 시퀀스명.NEXTVAL : 다음 번호 발행 NEXT
		 * 시퀀스명.CURRVAL : 현재 번호 확인 CURRENT(NEXTVAL 한번 이상 호출 후 사용가능)
		 */

	

	}

}
